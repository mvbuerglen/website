---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatTime } from "./time.js";

export interface Props {
  item: CollectionEntry<"anlaesse">;
}

const { item } = Astro.props;
const localDate = item.data.datum;
---

<p>
  <time datetime={localDate.toISOString()}>{formatDate(localDate)}</time>
</p>
<a href={`/anlaesse/${item.id}`} class:list={["overlay-link"]}><h3>{item.data.title}</h3></a>
<p><time datetime={localDate.toISOString()}>{formatTime(localDate)}</time> in {item.data.ort}</p>
<style>
  p:first-child {
    color: var(--theme-colors-gray);
  }

  h3 {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
</style>
