---
import Anlaesse from "~/components/Anlaesse.astro";
import Layout from "~/layouts/Main.astro";

export interface Props {
  frontmatter?: object;
}

const { frontmatter } = Astro.props;
---

<Layout {...frontmatter}>
  <article class="prose">
    <slot />
  </article>
  <Anlaesse mode="all" count={4} />
</Layout>
