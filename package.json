{
  "name": "mv-buerglen",
  "type": "module",
  "version": "0.0.1",
  "author": {
    "name": "Sergey Shishkin",
    "email": "sergey@shishkin.org",
    "url": "https://shishkin.org"
  },
  "license": "Unlicense",
  "private": true,
  "engines": {
    "node": ">=24",
    "pnpm": ">=11 < 12"
  },
  "scripts": {
    "start": "node --watch server.ts",
    "generate": "node node_modules/@mastrojs/mastro/src/generator.js --output dist",
    "build": "pnpm check && pnpm generate",
    "check:biome": "biome check",
    "check:tsc": "tsc --noEmit",
    "check": "pnpm run --sequential \"/^check:.*/\""
  },
  "imports": {
    "#*": "./*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@mastrojs/markdown": "jsr:0.2.2",
    "@mastrojs/mastro": "jsr:0.8.9",
    "@remix-run/node-fetch-server": "0.13.3",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "^24",
    "sharp": "0.35.2",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
